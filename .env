# ===== OpenAI 基础配置 =====
OPENAI_API_KEY=#
OPENAI_CHAT_MODEL_ID=glm-5
OPENAI_BASE_URL=https://tokenhub.tencentmaas.com/v1

# ===== 模型配置 =====
REVIEW_MODEL_ID=glm-5
COVERAGE_MODEL_ID=glm-5

# ===== 服务器配置 =====
SERVER_HOST=127.0.0.1
SERVER_PORT=8001

# ===== Agent 超时配置 =====
AGENT_TIMEOUT_SECONDS=1000

# ===== 日志配置 =====
LOG_LEVEL=DEBUG
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_LEVEL=DEBUG
LOG_FILE_NAME=AITestCraft.log
LOG_RESULT_MAX_LENGTH=5000
LOG_DEBUG_MAX_LENGTH=200
LOG_ERROR_MAX_LENGTH=500
LOG_TASK_ID_LENGTH=8

# ===== CORS 配置 =====
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization

# ===== 限流配置 =====
API_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_WINDOW_SECONDS=60

# ===== 文件上传配置 =====
MAX_FILE_SIZE=10485760

# ===== PDF 解析配置 =====
#配置一个多模态的模型来解析PDF文件
PDF_VISION_MODEL_ID=deepseek-v4-flash
PDF_MAX_PAGES=50

# ===== 任务恢复配置 =====
TASK_RECOVERY_ENABLED=true
TASK_RECOVERY_INTERVAL=500
TASK_RECOVERY_MAX_COUNT=10

# ===== 飞书配置 =====
FEISHU_USER_ACCESS_TOKEN=

# ===== TAPD 配置 =====
TAPD_API_USER=
TAPD_API_PASSWORD=

# ===== 语雀配置 =====
YUQUE_API_TOKEN=

# ===== 石墨配置 =====
SHIMO_CLIENT_ID=
SHIMO_CLIENT_SECRET=
SHIMO_API_TOKEN=

# ===== Confluence 配置 =====
CONFLUENCE_BASE_URL=
CONFLUENCE_EMAIL=
CONFLUENCE_API_TOKEN=
