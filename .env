OPENAI_API_KEY=你的key
OPENAI_CHAT_MODEL_ID=zai-org/GLM-4.6
OPENAI_BASE_URL=https://api.siliconflow.cn/v1/
# CORS 配置
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization

# API 限流配置
API_RATE_LIMIT_PER_MINUTE=5
API_RATE_LIMIT_WINDOW_SECONDS=60

# 服务配置
SERVER_HOST=0.0.0.0
SERVER_PORT=8001
# 日志配置
LOG_LEVEL=INFO
LOG_CONSOLE_LEVEL=INFO
LOG_FILE_LEVEL=DEBUG
LOG_FILE_NAME=AITestCraft.log
LOG_TASK_MAX_LENGTH=200
LOG_RESULT_MAX_LENGTH=5000
LOG_DEBUG_MAX_LENGTH=200
LOG_ERROR_MAX_LENGTH=500
LOG_TASK_ID_LENGTH=8